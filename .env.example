# Supabase (https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role — local dev / CI only; never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL (SEO canonical, Open Graph, sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Contact form (SMTP) — see docs/SMTP_SETUP.md
# Gmail example:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=karpolpolyurethane@gmail.com
SMTP_PASS=
CONTACT_TO=karpolpolyurethane@gmail.com
CONTACT_FROM=Karpol İletişim <karpolpolyurethane@gmail.com>

# E2E / local admin test user (optional)
E2E_ADMIN_EMAIL=admin@example.com
E2E_ADMIN_PASSWORD=
